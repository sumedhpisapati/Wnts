import numpy as np
import matplotlib.pyplot as plt
from shapely.geometry import box

class SwedenVoxelMap:
    def __init__(self, res_meters=50):
        # 1. Geographic Bounds (Karlshamn Port/Center)
        self.min_lat, self.max_lat = 56.14, 56.18
        self.min_lon, self.max_lon = 14.82, 14.88
        self.res = res_meters
        
        # 2. Grid Dimensions (Approximate conversion: 1 deg lat ~ 111km)
        # We calculate how many 'res' meter steps fit in our lat/lon span
        self.rows = int((self.max_lat - self.min_lat) * 111000 / self.res)
        self.cols = int((self.max_lon - self.min_lon) * 62000 / self.res)
        
        # 3. The Risk Matrix (0.0 = Safe, 1.0 = Danger)
        self.grid = np.zeros((self.rows, self.cols))
        self._initialize_static_risks()

    def _initialize_static_risks(self):
        """Simulates Layer 1: Assigning risk based on known landmarks."""
        # Example: Setting a 'Forbidden' zone for the Oil Terminal/Port
        # In a real app, you'd load a GeoJSON here.
        mid_r, mid_c = self.rows // 2, self.cols // 2
        self.grid[mid_r-10:mid_r+10, mid_c-20:mid_c+5] = 1.0  # Port area
        
        # Example: Coastal water (Lower risk)
        self.grid[0:self.rows//3, :] = 0.1 

    def query_risk(self, lat, lon):
        """Translates a real coordinate into a grid index and returns risk."""
        r = int((lat - self.min_lat) / (self.max_lat - self.min_lat) * self.rows)
        c = int((lon - self.min_lon) / (self.max_lon - self.min_lon) * self.cols)
        
        if 0 <= r < self.rows and 0 <= c < self.cols:
            return self.grid[r, c]
        return None # Out of bounds

    def visualize(self):
        plt.figure(figsize=(10, 6))
        plt.imshow(self.grid, extent=[self.min_lon, self.max_lon, self.min_lat, self.max_lat], 
                   origin='lower', cmap='RdYlGn_r')
        plt.colorbar(label="Wreckage Risk Score")
        plt.title(" Engagement Acceptability Grid")
        plt.xlabel("Longitude")
        plt.ylabel("Latitude")
        plt.show()

# --- Execution ---
kvm = SwedenVoxelMap(res_meters=50)
kvm.visualize()

# Example Query
test_lat, test_lon = 56.16, 14.85
print(f"Risk at ({test_lat}, {test_lon}): {kvm.query_risk(test_lat, test_lon)}")
